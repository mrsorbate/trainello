# trainello root environment template
# Copy to .env and adjust values for your server.

# Common
BACKEND_PORT=3000
FRONTEND_PORT=8080
DATABASE_PATH=/app/data/database.sqlite
BACKEND_DATA_DIR=./data/backend
BACKEND_UPLOADS_DIR=./data/uploads
JWT_SECRET=change-me-in-production

# Production domain (set per instance/club)
DOMAIN=app.svhochweisel.de
FRONTEND_URL=https://app.svhochweisel.de
ACME_EMAIL=admin@svhochweisel.de

# Web Push (required for notifications)
# setup-server.sh auto-generates VAPID keys when COMPOSE_FILE=docker-compose.prod.yml
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@svhochweisel.de

# Optional security and auth tuning
# JWT_EXPIRES_IN=7d
# API_RATE_LIMIT_WINDOW_MS=900000
# API_RATE_LIMIT_MAX=300
# AUTH_RATE_LIMIT_MAX=20
# LOGIN_RATE_LIMIT_WINDOW_MS=900000
# LOGIN_RATE_LIMIT_MAX=8
